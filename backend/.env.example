# Copy to .env and fill in. Every key is optional — the pipeline degrades to a
# fully-functional offline simulation when an integration is not configured.

# --- Anthropic (auto-remediation via Claude Code) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_ID=claude-opus-4-8

# --- MiniMax (fuzzer + ensemble LLM-judge) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3
# MINIMAX_GROUP_ID=        # enables real embo-01 embeddings; else local fallback
EMBEDDING_DIM=512

# --- Redis Stack (vector DB + agent memory) ---
REDIS_URL=redis://localhost:6379/0

# --- Arize AX tracing (preferred) ---
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=riposte-audits

# --- Phoenix tracing (fallback when Arize AX unset) ---
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_PROJECT_NAME=riposte-audits

# --- Sentry (error telemetry) ---
SENTRY_DSN=

# --- Browserbase / Stagehand (execution arm) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_MODEL=anthropic/claude-haiku-4-5-20251001

# --- GitHub (HITL remediation PRs) ---
GITHUB_TOKEN=

# --- Pipeline tuning ---
MAX_CONCURRENT_SESSIONS=10
OFFENSIVE_WORKERS=3
EVAL_WORKERS=2
REMEDIATION_WORKERS=1
ARIES_CRITICAL_THRESHOLD=75.0
MAX_INPUT_CHARS=20000
