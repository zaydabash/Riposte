# Copy to .env and fill in. Integrations that are not configured cause the
# corresponding pipeline stage to fail closed rather than simulate results.

# --- Anthropic (auto-remediation via Claude Code) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_ID=claude-opus-4-8

# --- MiniMax (fuzzer + ensemble LLM-judge) ---
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.tokenrouter.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_EMBEDDING_MODEL=embo-01
# MINIMAX_GROUP_ID=        # optional for native MiniMax; TokenRouter does not require it
EMBEDDING_BACKEND=local    # local or remote
EMBEDDING_DIM=512

# --- Redis Stack (vector DB + agent memory) ---
# Local only — no API key or password required. Use docker compose for RediSearch:
#   docker compose up -d redis
REDIS_URL=redis://localhost:6379/0

# --- Sentry (error telemetry) ---
SENTRY_DSN=

# --- Browserbase / Stagehand (execution arm) ---
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
STAGEHAND_MODEL=anthropic/claude-haiku-4-5-20251001

# --- GitHub (HITL remediation PRs) ---
GITHUB_TOKEN=

# --- Pipeline tuning ---
MAX_CONCURRENT_SESSIONS=15
SCENARIO_WORKERS=2
VERIFICATION_WORKERS=3
EVAL_WORKERS=2
REMEDIATION_WORKERS=1
FUZZER_WORKERS=2
OFFENSIVE_WORKERS=3
ARIES_CRITICAL_THRESHOLD=75.0
ARIES_SEVERITY_HIGH_THRESHOLD=55.0
ARIES_SEVERITY_MEDIUM_THRESHOLD=35.0
ARIES_SEVERITY_LOW_THRESHOLD=15.0
ARIES_CONTROL_PASS_A_CAP=15.0
ARIES_WEIGHT_M=0.35
ARIES_WEIGHT_L=0.35
ARIES_WEIGHT_A=0.20
ARIES_WEIGHT_J=0.10
ARIES_LEAK_DOC_THRESHOLD=50.0
MINIMAX_JUDGE_ENSEMBLE_SIZE=3
MAX_INPUT_CHARS=20000
MAX_DASHBOARD_FIELD_CHARS=2000
MAX_ERROR_DETAIL_CHARS=500
ANTHROPIC_HTTP_TIMEOUT=60.0
CLAUDE_MAX_TOKENS=4000
CLAUDE_TEMPERATURE=0.2
MINIMAX_HTTP_TIMEOUT=20.0
REDIS_SOCKET_TIMEOUT=3.0
GITHUB_HTTP_TIMEOUT=30.0
GITHUB_DEFAULT_BRANCH=main
SENTRY_TRACES_SAMPLE_RATE=1.0
CORS_ALLOWED_ORIGINS=*
