# Backend base URL for the Riposte control plane.
NEXT_PUBLIC_RIPOSTE_API_URL=http://127.0.0.1:8000

# Optional dashboard defaults (form pre-fill).
# NEXT_PUBLIC_RIPOSTE_MAX_PAYLOADS=10
# NEXT_PUBLIC_RIPOSTE_MAX_PAYLOADS_LIMIT=50
# NEXT_PUBLIC_RIPOSTE_POLL_MS=1000
# NEXT_PUBLIC_RIPOSTE_POLL_MIN_MS=250

# ARiES display thresholds (mirror backend ARIES_* where noted).
# NEXT_PUBLIC_ARIES_CRITICAL_THRESHOLD=75
# NEXT_PUBLIC_ARIES_LEAK_THRESHOLD=50
# NEXT_PUBLIC_ARIES_BAND_MEDIUM_THRESHOLD=40

# ARiES formula weights (mirror backend ARIES_WEIGHT_* / leakage blend).
# NEXT_PUBLIC_ARIES_WEIGHT_M=0.35
# NEXT_PUBLIC_ARIES_WEIGHT_L=0.35
# NEXT_PUBLIC_ARIES_WEIGHT_A=0.2
# NEXT_PUBLIC_ARIES_WEIGHT_J=0.1
# NEXT_PUBLIC_LEAKAGE_COS_WEIGHT=0.5
# NEXT_PUBLIC_LEAKAGE_ENTITY_WEIGHT=0.3
# NEXT_PUBLIC_LEAKAGE_TOKEN_WEIGHT=0.2
